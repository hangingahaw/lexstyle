{
  "name": "lexstyle",
  "version": "0.2.0",
  "description": "Structured typography rules for LLM-based text correction tools",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "typography",
    "style-guide",
    "dashes",
    "punctuation",
    "llm",
    "legal-writing",
    "editorial",
    "text-correction"
  ],
  "author": "Haihang Wang",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hangingahaw/lexstyle.git"
  },
  "homepage": "https://github.com/hangingahaw/lexstyle#readme",
  "bugs": {
    "url": "https://github.com/hangingahaw/lexstyle/issues"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
